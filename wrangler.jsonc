{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "my-app",
  "main": "src/api.ts",
  "compatibility_date": "2024-04-19",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "hyperdrive": [
    {
      "binding": "fandomaurora",
      "id": "YOUR_HYPERDRIVE_ID",
      "localConnectionString": "postgres://localhost:5432/postgres"
    }
  ]
}